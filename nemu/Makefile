# Sanity check
ifeq ($(wildcard $(NEMU_HOME)/src/nemu-main.c),)
  $(error NEMU_HOME=$(NEMU_HOME) is not a NEMU repo)
endif

fpga-mailbox-test:
	@bash "$(NEMU_HOME)/tests/run-fpga-mailbox-test.sh"

pipeline-html-test:
	@bash "$(NEMU_HOME)/tests/run-pipeline-html-test.sh"

performance-html-test:
	@bash "$(NEMU_HOME)/tests/run-performance-html-test.sh"

.PHONY: fpga-mailbox-test pipeline-html-test performance-html-test

# Keep native, ZCU102 cross-host and U55C host configurations independent.
# Defaults preserve the historical in-tree paths.
NEMU_CONFIG_ROOT ?= $(NEMU_HOME)
NEMU_BUILD_ROOT ?= $(NEMU_HOME)/build
NEMU_CONFIG_FILE := $(NEMU_CONFIG_ROOT)/.config
NEMU_AUTO_CONF := $(NEMU_CONFIG_ROOT)/include/config/auto.conf
NEMU_AUTO_CONF_CMD := $(NEMU_CONFIG_ROOT)/include/config/auto.conf.cmd
NEMU_AUTO_HEADER := $(NEMU_CONFIG_ROOT)/include/generated/autoconf.h
NEMU_TRISTATE_CONF := $(NEMU_CONFIG_ROOT)/include/config/tristate.conf
export KCONFIG_CONFIG := $(NEMU_CONFIG_FILE)
export KCONFIG_AUTOCONFIG := $(NEMU_AUTO_CONF)
export KCONFIG_AUTOHEADER := $(NEMU_AUTO_HEADER)
export KCONFIG_TRISTATE := $(NEMU_TRISTATE_CONF)

# Include variables and rules generated by menuconfig
-include $(NEMU_AUTO_CONF)
-include $(NEMU_AUTO_CONF_CMD)

ifneq ($(filter y,$(CONFIG_FPGA_BACKEND_ZCU102) $(CONFIG_FPGA_BACKEND_U55C)),)
CFLAGS += -DNPC -DNPC_FPGA_REMOTE
INC_PATH += $(NEMU_HOME)/../npc/csrc
endif

ifeq ($(CONFIG_FPGA_BACKEND_U55C),y)
XRT_ROOT ?= $(XILINX_XRT)
ifeq ($(wildcard $(XRT_ROOT)/include/xrt/xrt_device.h),)
$(error U55C FPGA backend requires XRT_ROOT or XILINX_XRT to name an XRT development installation)
endif
CXXFLAGS += -std=c++17
INC_PATH += $(XRT_ROOT)/include
LIBS += -L$(XRT_ROOT)/lib -Wl,-rpath,$(XRT_ROOT)/lib -lxrt_coreutil -luuid -pthread
endif

remove_quote = $(patsubst "%",%,$(1))

# Extract variabls from menuconfig
GUEST_ISA ?= $(call remove_quote,$(CONFIG_ISA))
ENGINE ?= $(call remove_quote,$(CONFIG_ENGINE))
NAME    = $(GUEST_ISA)-nemu-$(ENGINE)

# Include all filelist.mk to merge file lists
FILELIST_MK = $(shell find -L ./src -name "filelist.mk")
include $(FILELIST_MK)

# Filter out directories and files in blacklist to obtain the final set of source files
DIRS-BLACKLIST-y += $(DIRS-BLACKLIST)
SRCS-BLACKLIST-y += $(SRCS-BLACKLIST) $(shell find -L $(DIRS-BLACKLIST-y) -name "*.c")
SRCS-y += $(shell find -L $(DIRS-y) -name "*.c")
SRCS = $(filter-out $(SRCS-BLACKLIST-y),$(SRCS-y))

# Extract compiler and options from menuconfig
ifneq ($(CONFIG_CC),)
CC = $(call remove_quote,$(CONFIG_CC))
endif
CFLAGS_BUILD += $(call remove_quote,$(CONFIG_CC_OPT))
CFLAGS_BUILD += $(if $(CONFIG_CC_LTO),-flto,)
CFLAGS_BUILD += $(if $(CONFIG_CC_DEBUG),-Og -ggdb3,)
CFLAGS_BUILD += $(if $(CONFIG_CC_ASAN),-fsanitize=address,)
CFLAGS_TRACE += -DITRACE_COND=$(if $(CONFIG_ITRACE_COND),$(call remove_quote,$(CONFIG_ITRACE_COND)),true)
CFLAGS  += $(CFLAGS_BUILD) $(CFLAGS_TRACE) -D__GUEST_ISA__=$(GUEST_ISA)

# The interpreter owns a separate SoftFloat archive.  It uses the vendored
# source tree, but never consumes NPC's intermediate build products.
ifeq ($(CONFIG_RISCV_F),y)
SOFTFLOAT_HOME ?= $(NEMU_HOME)/../npc/chisel/ysyxSoC/rocket-chip/dependencies/hardfloat/berkeley-softfloat-3
SOFTFLOAT_SOURCE ?= $(SOFTFLOAT_HOME)/source
SOFTFLOAT_TEMPLATE ?= $(SOFTFLOAT_HOME)/build/Linux-x86_64-GCC
SOFTFLOAT_BUILD_DIR ?= $(NEMU_BUILD_ROOT)/softfloat
SOFTFLOAT_LIB ?= $(SOFTFLOAT_BUILD_DIR)/softfloat.a
SOFTFLOAT_CC ?= $(CC)
SOFTFLOAT_AR ?= $(if $(filter %gcc,$(notdir $(SOFTFLOAT_CC))),$(patsubst %gcc,%ar,$(SOFTFLOAT_CC)),ar)
SOFTFLOAT_INPUTS := $(shell find "$(SOFTFLOAT_SOURCE)" "$(SOFTFLOAT_TEMPLATE)" -type f 2>/dev/null)
CFLAGS += -I$(SOFTFLOAT_SOURCE)/include
ARCHIVES += $(SOFTFLOAT_LIB)

$(SOFTFLOAT_LIB): $(SOFTFLOAT_INPUTS)
	@set -e; \
	test -f "$(SOFTFLOAT_TEMPLATE)/Makefile" || { echo "SoftFloat build template not found: $(SOFTFLOAT_TEMPLATE)" >&2; exit 2; }; \
	rm -rf "$(SOFTFLOAT_BUILD_DIR)"; mkdir -p "$(SOFTFLOAT_BUILD_DIR)"; \
	cp "$(SOFTFLOAT_TEMPLATE)/platform.h" "$(SOFTFLOAT_BUILD_DIR)/platform.h"; \
	$(MAKE) -C "$(SOFTFLOAT_BUILD_DIR)" -f "$(SOFTFLOAT_TEMPLATE)/Makefile" \
		SOURCE_DIR="$(SOFTFLOAT_SOURCE)" SPECIALIZE_TYPE=RISCV \
		COMPILE_C='$(SOFTFLOAT_CC) -c -Werror-implicit-function-declaration -DSOFTFLOAT_FAST_INT64 $$(SOFTFLOAT_OPTS) $$(C_INCLUDES) -O2 -o $$@' \
		MAKELIB='$(SOFTFLOAT_AR) crs $$@'
endif

# Add NPC flag if NPC mode is enabled
ifeq ($(USENPC), 1)
CFLAGS += -DNPC
ifeq ($(CONFIG_NPC_VCD_TRACE),y)
CFLAGS += -DNPC_VCD_TRACE
endif
ifeq ($(NPC_SOC), 1)
CFLAGS += -DNPC_SOC
endif
endif

LDFLAGS += $(CFLAGS_BUILD)

# Include rules for menuconfig
include $(NEMU_HOME)/scripts/config.mk

ifdef CONFIG_TARGET_AM
include $(AM_HOME)/Makefile
LINKAGE += $(ARCHIVES)
else
# Include rules to build NEMU
include $(NEMU_HOME)/scripts/native.mk
endif
